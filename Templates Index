<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>GEAM - Sistema de Nominaciones</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 p-8">
    <div class="max-w-4xl mx-auto bg-white p-6 rounded-xl shadow-lg">
        <header class="flex justify-between items-center border-bottom pb-4 mb-6">
            <h1 class="text-2xl font-bold text-blue-900">GEAM Energy - Nominaciones</h1>
            <div id="ventana-info" class="text-right">
                <span id="label-reloj" class="text-sm font-semibold uppercase">Cierre de Ventana en:</span>
                <div id="countdown" class="text-2xl font-mono text-red-600">00:00:00</div>
            </div>
        </header>

        <form id="nominacion-form" class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-gray-700">Contrato</label>
                <select id="contrato" class="w-full p-2 border rounded" required>
                    <option value="CONT-001">CONT-001 (Empresa Alfa)</option>
                    <option value="CONT-002">CONT-002 (Empresa Beta)</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700">Cantidad (MBTU)</label>
                <input type="number" id="cantidad" class="w-full p-2 border rounded" placeholder="0.00" required>
            </div>
            <!-- Otros campos como Fuente, Punto, Sector se llenan igual -->
            <div class="col-span-2">
                <button type="submit" class="w-full bg-blue-600 text-white py-3 rounded-lg font-bold hover:bg-blue-700">
                    ENVIAR NOMINACIÓN
                </button>
            </div>
        </form>
    </div>
    <script src="/static/js/script.js"></script>
</body>
</html>
